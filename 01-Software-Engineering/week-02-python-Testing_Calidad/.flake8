[flake8]
# Ignorar errores que chocan con el formateador Black
ignore = E203, E266, E501, W503
# Un Senior usa 88 caracteres (estándar moderno de Python)
max-line-length = 88
max-complexity = 18
select = B,C,E,F,W,T4,B9
# No revisar carpetas de sistema o entorno
exclude =
    .git,
    __pycache__,
    venv,
    .pytest_cache,
    .coverage,
    .mypy_cache
